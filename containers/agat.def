agat_convert_sp_gxf2gxf.pl, agat_sp_fix_features_locations_duplicated.pl, agat_sq_add_hash_tag.pl, agat_sp_add_attribute_shortest_exon_size.pl, agat_sp_fix_fusion.pl, agat_sq_add_locus_tag.pl,
