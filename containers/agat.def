agat_sp_clipN_seqExtremities_and_fixCoordinates.pl, agat_sp_flag_short_introns.pl, agat_sq_manage_IDs.pl, agat_sp_compare_two_annotations.pl, agat_sp_functional_statistics.pl, agat_sq_mask.pl,
agat_sp_compare_two_BUSCOs.pl, agat_sp_keep_longest_isoform.pl, agat_sq_remove_redundant_entries.pl, agat_sp_complement_annotations.pl, agat_sp_kraken_assess_liftover.pl, agat_sq_repeats_analyzer.pl,
agat_sp_ensembl_output_style.pl, agat_sp_list_short_introns.pl, agat_sq_reverse_complement.pl, agat_sp_extract_attributes.pl, agat_sp_load_function_from_protein_align.pl, agat_sq_rfam_analyzer.pl,
agat_sp_extract_sequences.pl, agat_sp_manage_attributes.pl, agat_sq_split.pl, agat_sp_filter_by_locus_distance.pl, agat_sp_manage_functional_annotation.pl, agat_sq_stat_basic.pl,
