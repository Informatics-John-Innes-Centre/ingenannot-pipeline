agat_sp_filter_feature_from_kill_list.pl, agat_sp_Prokka_inferNameFromAttributes.pl, agat_convert_minimap2_bam2gff.pl, agat_sp_filter_gene_by_intron_numbers.pl, agat_sp_sensitivity_specificity.pl,
agat_convert_sp_gff2bed.pl, agat_sp_filter_gene_by_length.pl, agat_sp_separate_by_record_type.pl, agat_convert_sp_gff2gtf.pl, agat_sp_filter_incomplete_gene_coding_models.pl, agat_sp_statistics.pl,
