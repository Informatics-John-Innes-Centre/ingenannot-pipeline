Bootstrap: docker
From: nvidia/cuda:13.2.0-cudnn-runtime-ubuntu24.04

%labels
    Author William Redding
    Version 2.3.2
    Description "Ubuntu container for ANNEVO"
    Provides annevo-predict annevo-decode annevo-annotate annevo-generate-datasets annevo-model-train annevo-fine-tune
    Institute JIC
%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/opt/software/bin:/opt/miniforge3/condabin:$PATH
    export PYTHONPATH=/opt/ANNEVO:$PYTHONPATH
    export NUMBA_CACHE_DIR=/tmp
%post
    apt-get update
    apt-get install -y wget git vim ca-certificates less which locales-all
    apt-get clean
    rm -rf /var/lib/apt/lists/*
    mkdir -p /opt
    cd /opt
    RELEASE="Miniforge3-Linux-x86_64.sh"
    wget "https://github.com/conda-forge/miniforge/releases/latest/download/${RELEASE}"
    bash $RELEASE -b -p /opt/miniforge3
    rm -f $RELEASE
    rm -f /opt/miniforge3/.condarc
    export PATH=/opt/miniforge3/condabin:$PATH
    git clone --depth 1 --branch v2.3.2 https://github.com/xjtu-omics/ANNEVO
    conda env create -f ANNEVO/ANNEVO.yml -p /opt/software
    conda clean -afy
    ln -s /tmp /opt/ANNEVO/tmp
    
    # wrapper scripts
    # annevo predict
    cat > /usr/local/bin/annevo-predict << 'EOF'
#!/bin/bash
exec python /opt/ANNEVO/prediction.py "$@"
EOF
    chmod +x /usr/local/bin/annevo-predict
    # annevo decode
    cat > /usr/local/bin/annevo-decode << 'EOF'
#!/bin/bash
exec python /opt/ANNEVO/decoding.py "$@"
EOF
    chmod +x /usr/local/bin/annevo-decode

    # annevo annotate
    cat > /usr/local/bin/annevo-annotate << 'EOF'
#!/bin/bash
exec python /opt/ANNEVO/annotation.py "$@"
EOF
    chmod +x /usr/local/bin/annevo-annotate

%test
    set -env
    annevo-annotate -h
    annevo-decode -h
    annevo-predict -h
