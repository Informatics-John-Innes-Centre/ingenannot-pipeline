Bootstrap: docker
From: nvidia/cuda:12.2.0-base-ubuntu22.04

%labels
    Author "Miguel Gonzalez Sanchez"
    Version "1.0"
    Description "Singularity container for Helixer + HelixerPost with GPU support"

%environment
    export PATH=/opt/helixer/env/bin:/opt/helixer/HelixerPost/target/release:$PATH

%post
    # Install system dependencies
    apt-get update && apt-get install -y \
        python3.10 \
        python3.10-dev \
        python3.10-venv \
        python3-pip \
        git \
        build-essential \
        wget \
        curl \
        libhdf5-dev \
        pkg-config \
        && apt-get clean \
        && rm -rf /var/lib/apt/lists/*

    # Install Rust (stable)
    curl https://sh.rustup.rs -sSf | bash -s -- -y
    export PATH=$PATH:/root/.cargo/bin

    mkdir -p /opt/helixer
    cd /opt/helixer

    # Clone repositories
    git clone https://github.com/weberlab-hhu/Helixer.git
    git clone https://github.com/TonyBolger/HelixerPost.git

    # Create Python virtual environment
    python3.10 -m venv env
    . env/bin/activate

    # Upgrade pip & install dependencies
    pip install --upgrade pip
    pip install wheel

    cd /opt/helixer/Helixer
    pip install -r requirements.3.10.txt
    pip install .

    # Build HelixerPost with cargo
    cd /opt/helixer/HelixerPost
    cargo build --release

    # Optional: copy binary to virtualenv bin dir
    cp target/release/helixer_post_bin /opt/helixer/env/bin/

    # Install tensorflow with GPU support
    pip install tensorflow[and-cuda]

    cd /opt/helixer/Helixer
    sed -i "s|MODEL_LIST_URL = 'https://raw.githubusercontent.com/weberlab-hhu/Helixer/main/resources/model_list.csv'|MODEL_LIST_URL = None|" helixer/core/data.py
    sed -i "s|response = urllib.request.urlopen(MODEL_LIST_URL)|# response = urllib.request.urlopen(MODEL_LIST_URL)|" helixer/core/data.py
